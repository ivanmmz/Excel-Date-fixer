{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/v2/core/tauri-config-schema/schema.json",
  "productName": "ExcelDateFixerPro",
  "version": "1.0.0",
  "identifier": "com.maivan.datefixer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Excel Date Fixer",
        "width": 1050,
        "height": 720,
        "minWidth": 950,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}